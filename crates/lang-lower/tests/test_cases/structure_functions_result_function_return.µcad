fn pow(x: Scalar, n: Integer) -> Scalar {
    if n > 1 {
        return x * pow(x, n - 1);
    }
    if n < 1 {
        return 1.0 / x / pow(x, -n);
    }
    1.0
}

std::debug::assert_eq([pow(8.0, 2), 64.0]);
std::debug::assert_eq([pow(8.0, -2), 0.015625]);
