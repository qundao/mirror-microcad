   9:   use std::geo2d::*;
  10:   use std::ops::*;
  11:   
  12:   mod logo;
  13:   
  14:   use logo::microcad::Logo;
  15:   
  16:   const TEETH_SIZE = 0.5mm;
  17:   const THICKNESS = 2mm;
  18:   const BORDER_WIDTH = 7mm;
  19:   
  20:   sketch GearProfile(teeth: Integer) {
  21:       prop module = TEETH_SIZE;
  22:       prop radius = teeth * module;
  23:       SinusoidalGearProfile(module, teeth, stretch = 0.6, roundness = 0.6);
  24:   }
  25:   
  26:   sketch RingProfile(
  27:       outer_teeth: Integer,
  28:       inner_teeth: Integer,
  29:       border_width = BORDER_WIDTH,
  30:   ) {
  31:       inner_gear = GearProfile(inner_teeth);
  32:       outer_gear = GearProfile(outer_teeth);
  33:       prop radius = outer_gear.radius;
  34:       prop shift = inner_gear.radius * 40%;
  35:   
  36:       sector = {
  37:           disc = Circle(r = outer_gear.radius - border_width);
  38:           sector = Sector(r = outer_gear.radius, start = 30°, end = 90°).rotate(60°);
  39:           inner_disc = Circle(r = inner_gear.radius - border_width * 250%);
  40:           ring = Ring(
  41:               o_r = inner_gear.radius + border_width - TEETH_SIZE * 2,
  42:               thickness = border_width,
  43:           );
  44:   
  45:           (disc - (sector - inner_disc) - ring.translate(x = shift))
  46:               .buffer(-TEETH_SIZE * 2)
  47:               .buffer(TEETH_SIZE * 2);
  48:       };
  49:   
  50:       outer_gear - sector - inner_gear.translate(x = shift);
  51:   }
  52:   
  53:   part PencilHole(pencil_hole_diameter = 0.5mm, offset = 0.0mm) {
  54:       Circle(d = pencil_hole_diameter)
  55:           .extrude(THICKNESS, scale = (x = 300%, y = 300%))
  56:           .translate(y = offset);
  57:   }
  58:   
  59:   part PencilHoles(radius: Length, n = 4, start = 4, angle = 22.5°) {
  60:       {
  61:           PencilHole(offset = [start..n * 2 - 1] * radius / n / 2);
  62:           PencilHole(offset = ([start..n * 2 - 1] + 0.5) * radius / n / 2).rotate(-angle);
  63:           PencilHole(offset = ([start..n * 2 - 1] + 1 / 3) * radius / n / 2).rotate(angle);
  64:       }.rotate(90°);
  65:   }
  66:   
  67:   #[export = "spirograph_frame.stl"]
  68:   #[color = std::color::BLUE]
  69:   {
  70:       outer_gear = GearProfile(180);
  71:       size = outer_gear.radius * 200% + 3 * BORDER_WIDTH;
  72:       frame = {
  73:           border = RoundedRect(size, radius = BORDER_WIDTH * 200%);
  74:           border - outer_gear;
  75:       }.extrude(THICKNESS * 2);
  76:   
  77:       logo2 = Logo(size = BORDER_WIDTH * 85%)
  78:           .extrude(THICKNESS)
  79:           .translate(x = size * 35%, y = size * 43%, z = THICKNESS * 150%);
  80:   
  81:       url = Text("microcad.xyz", BORDER_WIDTH * 150%)
  82:           .center()
  83:           .extrude(THICKNESS)
  84:           .translate(x = size * 32%, y = -size * 46%, z = THICKNESS * 150%);
  85:   
  86:       frame - logo2 - url;
  87:   }.translate(x = 0mm);
  88:   
  89:   ring_1 = RingProfile(outer_teeth = 180, inner_teeth = 120);
  90:   ring_2 = RingProfile(outer_teeth = 120, inner_teeth = 72);
  91:   ring_3 = RingProfile(outer_teeth = 72, inner_teeth = 36);
  92:   
  93:   #[export = "spirograph_ring_1.stl"]
  94:   #[color = std::color::GREEN]
  95:   {
  96:       ring = ring_1.extrude(THICKNESS);
  97:       pencil_holes = PencilHoles(ring_1.radius, n = 6, start = 6);
  98:       ring - pencil_holes;
  99:   }.translate();
 100:   
 101:   #[export = "spirograph_ring_2.stl"]
 102:   #[color = std::color::RED]
 103:   {
 104:       ring = ring_2.extrude(THICKNESS);
 105:       pencil_holes = PencilHoles(ring_2.radius, n = 5, start = 5);
 106:       ring - pencil_holes;
 107:   }.translate(x = ring_1.shift);
 108:   
 109:   #[export = "spirograph_ring_3.stl"]
 110:   #[color = std::color::YELLOW]
 111:   {
 112:       ring = ring_3.extrude(THICKNESS);
 113:       pencil_holes = PencilHoles(ring_3.radius);
 114:       ring - pencil_holes;
 115:   }.translate(x = ring_2.shift + ring_1.shift);
 116:   
 117:   gear = {
 118:       profile = GearProfile(36);
 119:       gear = profile.extrude(THICKNESS);
 120:       pencil_holes = PencilHoles(profile.radius, start = 1, n = 2, 120°);
 121:   
 122:       gear - pencil_holes;
 123:   };
 124:   
