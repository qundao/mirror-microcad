   9:   use std::math::*;
  10:   use std::ops::*;
  11:   use std::geo3d::*;
  12:   use std::geo2d::*;
  13:   
  14:   part Letter(letter: String, size: Length, axis: Vec3) {
  15:       Text(letter, height = size)
  16:           .center()
  17:           .contour(thickness = 0.25mm, distance = 0.5mm)
  18:           .extrude(1mm)
  19:           .translate(z = size / 2 - 0.5mm)
  20:           .orient(axis);
  21:   }
  22:   
  23:   part LetterCube(size: Length) {
  24:       s = size / sqrt(2.1);
  25:       body = Cube(size) & Sphere(r = s);
  26:       p = Letter("P", size, [-Z, Z]).rotate(z = -90°);
  27:       t = Letter("T", size, [-X, X]).rotate(x = 90°);
  28:       f = Letter("F", size, [-Y, Y]);
  29:       body - (p | t | f);
  30:   }
  31:   
  32:   LetterCube(20mm).translate(z = 10mm);

