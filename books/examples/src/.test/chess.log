  22:   }
  23:   
  24:   pub part King() {
  25:       {
  26:           Cube(BASE_SIZE);
  27:           Cube(BASE_SIZE / sqrt(2)).rotate(45°);
  28:       }.align(Z);
  29:   }
  30:   
  31:   pub part Queen() {
  32:       {
  33:           Cube(BASE_SIZE);
  34:           Sphere(diameter = BASE_SIZE / sqrt(2));
  35:       }.align(Z);
  36:   }
  37:   
  38:   pub part Bishop() {
  39:       size = BASE_SIZE / 3;
  40:       Rect(size * 90%)
  41:           .translate(size * 150%, [45, -135]°)
  42:           .hull()
  43:           .mirror(X)
  44:           .union()
  45:           .extrude(BASE_SIZE)
  46:           .rotate(x = 90°)
  47:           .center()
  48:   }
  49:   
  50:   pub part Rook() {
  51:       Cube(BASE_SIZE)
  52:   }
  53:   
  54:   pub part Knight() {
  55:       {
  56:           height = BASE_SIZE / 2;
  57:           r = Rect(BASE_SIZE);
  58:           (r - r.translate(x = height, y = height)).extrude(height);
  59:       }.rotate([0, 90]°).align(Z);
  60:   }
  61:   
