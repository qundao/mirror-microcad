  15:   // https://de.wikipedia.org/wiki/Bauhaus-Schachspiel
  16:   
  17:   pub const TILE_SIZE = 5.8cm;
  18:   const BASE_SIZE = TILE_SIZE * 70%;
  19:   
  20:   pub part Pawn() {
  21:       Cube(BASE_SIZE * 80%)
  22:   }
  23:   
  24:   pub part King() {
  25:       {
  26:           Cube(BASE_SIZE);
  27:           Cube(BASE_SIZE / sqrt(2)).rotate(45°);
  28:       }.align(Z);
  29:   }
  30:   
  31:   pub part Queen() {
  32:       {
  33:           Cube(BASE_SIZE);
  34:           Sphere(diameter = BASE_SIZE / sqrt(2));
  35:       }.align(Z);
  36:   }
  37:   
  38:   pub part Bishop() {
  39:       size = BASE_SIZE / 3;
  40:       Rect(size * 90%)
  41:           .translate(size * 150%, [45, -135]°)
  42:           .hull()
  43:           .mirror(X)
  44:           .union()
  45:           .extrude(BASE_SIZE)
  46:           .rotate(x = 90°)
  47:           .center()
  48:   }
  49:   
  50:   pub part Rook() {
  51:       Cube(BASE_SIZE)
  52:   }
  53:   
  54:   pub part Knight() {
  55:       {
  56:           height = BASE_SIZE / 2;
  57:           r = Rect(BASE_SIZE);
  58:           (r - r.translate(x = height, y = height)).extrude(height);
  59:       }.rotate([0, 90]°).align(Z);
  60:   }
  61:   
  62:   {
  63:       Rook();
  64:       Knight();
  65:       Bishop();
  66:       Queen();
  67:       King();
  68:       Bishop();
  69:       Knight().rotate(x = 180°).rotate(90°);
  70:       Rook();
  71:       8 * Pawn();
  72:   }
  73:   .distribute_grid(cell_size = TILE_SIZE, rows = 2, columns = 8)
  74:   .translate(y = TILE_SIZE * 3)
  75:   .rotate([0, 180]°);
  76:   
  77:   board_height = 1mm;
  78:   Rect(TILE_SIZE * 8).extrude(board_height).translate(z = -board_height);

