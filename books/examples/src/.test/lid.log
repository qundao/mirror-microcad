   9:   /// A part called `Lid` with three parameters.
  10:   part Lid(thickness = 1.6mm, inner_diameter = 16.0cm, height = 20.0mm) {
  11:       // Calculate the outer diameter
  12:       outer_diameter = 2.0 * thickness + inner_diameter;
  13:   
  14:       // Create two cylinders, one for the outer and one for the inner
  15:       outer = std::geo3d::Cylinder(d = outer_diameter, h = height);
  16:       inner = std::geo3d::Cylinder(d = inner_diameter, h = height).std::ops::translate(z = thickness);
  17:   
  18:       // Calculate the difference between two translated cylinders and output them
  19:       outer - inner;
  20:   }
