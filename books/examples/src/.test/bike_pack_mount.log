  18:       {
  19:           rd = (rack_rail_distance + rack_rail_diameter) / 2;
  20:           Circle(d = rack_rail_diameter, c = (x = [-0.5, 0.5]mm, y = 0mm))
  21:               .hull()
  22:               .translate(x = [-rd, rd]);
  23:       }
  24:       .extrude(40mm)
  25:       .orient(Y)
  26:       .translate(y = -15mm);
  27:   }
  28:   
  29:   part Mount(
  30:       height: Length,
  31:       screw_distance = 94mm,
  32:       screw_hole_diameter = 6mm,
  33:       rack_rail_distance = 100mm,
  34:       rack_rail_diameter = 10.5mm,
  35:   ) {
  36:       d = screw_distance / 2;
  37:       screws = Circle(d = screw_hole_diameter, c = (x = [-d, d], y = 0.0mm));
  38:   
  39:       Base().extrude(height) - screws.extrude(height + 10mm) - RackRails();
  40:   }
  41:   
  42:   pub part Lower() {
  43:       Mount(height = 15mm);
  44:   }
  45:   
  46:   pub part Upper() {
