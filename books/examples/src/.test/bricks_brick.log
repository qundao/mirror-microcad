  12:   use std::geo2d::*;
  13:   use std::ops::*;
  14:   use std::math::*;
  15:   
  16:   pub const SPACING = 8mm;
  17:   pub const THICKNESS = 1.2mm;
  18:   pub const BASE_HEIGHT = 9.6mm;
  19:   pub const TOLERANCE = 0.2mm;
  20:   
  21:   pub part Brick(rows = 2, columns = 4, base_height = BASE_HEIGHT) {
  22:       width = columns * SPACING - TOLERANCE;
  23:       height = rows * SPACING - TOLERANCE;
  24:   
  25:       base = {
  26:           Frame(width, height, THICKNESS);
  27:           r = rows - 1;
  28:           c = columns - 1;
  29:           n_rings = r * c;
  30:           if n_rings > 0 {
  31:               Ring(outer_diameter = 6.51mm, inner_diameter = 4.8mm)
  32:                   .multiply(n_rings)
  33:                   .distribute_grid(
  34:                       width = width - width / columns,
  35:                       height = height - height / rows,
  36:                       rows = r, 
  37:                       columns = c
  38:                   );
  39:           }
  40:       }
  41:       .extrude(base_height - THICKNESS);
  42:   
  43:       cap = Rect(width, height).extrude(THICKNESS);
  44:   
  45:       knobs = Circle(d = 4.8mm)
  46:           .multiply(rows * columns)
  47:           .distribute_grid(width, height, rows, columns)
  48:           .extrude(1.7mm);
  49:   
  50:       { base; cap; knobs; }.align(Z).union();
  51:   }
  52:   
  53:   n = 4;
  54:   
  55:   Brick(
  56:       rows = [1..n], 
  57:       columns = [1..n], 
  58:       base_height = BASE_HEIGHT * [1 / 3, 100%, 200%, 300%]
  59:   )
  60:   .distribute_grid(cell_size = n * 10mm, 
  61:       rows = 2*n, 
  62:       columns = 2*n,
  63:   );
  64:   

