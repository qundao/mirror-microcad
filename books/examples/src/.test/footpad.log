  12:   
  13:   part FootPad(
  14:       height = 45mm,
  15:       base = (x = 155mm, y = 101mm, z = 18mm),
  16:       slot = (x = 8mm, y = 13mm),
  17:       center_hole = (d_inner = 42mm, d_outer = 55mm),
  18:       corner_hole = (d_lower = 14mm, d_upper = 22mm),
  19:       corner_radius = 15mm,
  20:   ) {
  21:       s = (
  22:           x = base.x / 2 - corner_radius,
  23:           y = base.y / 2 - corner_radius,
  24:       );
  25:       hole_pos = (x = [-1, 1] * s.x, y = [-1, 1] * s.y);
  26:       radius = corner_radius;
  27:   
  28:       base_lower = Circle(radius, c = hole_pos)
  29:           .hull()
  30:           .extrude(12mm);
  31:   
  32:       base_upper_height = slot.x;
  33:       base_lower_height = base.z - base_upper_height;
  34:   
  35:       base_upper = {
  36:           top_left = (x = -s.x, y = s.y);
  37:           top_right = (x = s.x, y = s.y);
  38:           bottom_left = (x = -s.x, y = -s.y);
  39:           bottom_right = (x = s.x, y = -s.y);
  40:           (Circle(radius, c = (x = top_left.x, y = bottom_right.y)).hull()
  41:           | Circle(radius, c = (x = top_right.x, y = bottom_left.y)).hull());
  42:       }
  43:       .extrude(base_upper_height)
  44:       .translate(z = base_lower_height);
  45:   
  46:       center = {
  47:           (Circle(d = center_hole.d_outer) - Circle(d = center_hole.d_inner))
  48:               .extrude(height);
  49:   
  50:           Rect(height = slot.x, width = center_hole.d_outer)
  51:               .extrude(slot.y)
  52:               .translate(z = height - slot.y);
  53:   
  54:       }.subtract();
  55:   
  56:       holes = {
  57:           Circle(d = corner_hole.d_lower, c = hole_pos)
  58:               .extrude(height = base_lower_height);
  59:           Circle(d = corner_hole.d_upper, c = hole_pos)
  60:               .extrude(height = base.z * 2)
  61:               .translate(z = base_lower_height);
  62:           Circle(d = center_hole.d_inner)
  63:               .extrude(height);
  64:       }.union();
  65:   
  66:       base_lower | base_upper | center - holes;
  67:   }
  68:   
  69:   FootPad();

