 109:   use std::ops::*;
 110:   use std::geo2d::*;
 111:   use std::math::*;
 112:   
 113:   part Gear(teeth: Integer) {
 114:       gear_profile = InvoluteGearProfile(1.5mm, teeth);
 115:       prop outer_radius = gear_profile.outer_radius;
 116:       prop pitch_radius = gear_profile.pitch_radius;
 117:       prop tooth_angle = gear_profile.tooth_angle;
 118:       prop tooth_distance = gear_profile.tooth_distance;
 119:       prop module = gear_profile.module;
 120:   
 121:       disc = Circle(radius = pitch_radius - module * 400%);
 122:       web = {
 123:           sector = Sector(disc.radius, 360° / 5)
 124:               .buffer(-disc.radius * 15%)
 125:               .buffer(disc.radius * 12%);
 126:           holes = (sector - Circle(radius = module * 1000%))
 127:               .rotate([0..4] * 360° / 5);
 128:           hub = InvoluteGearProfile(2.5mm, 7);
 129:           disc - holes - hub;
 130:       }.extrude(tooth_distance * 300%).center();
 131:   
 132:       rim = (gear_profile - disc)
 133:           .extrude(tooth_distance * 200%, tooth_angle)
 134:           .mirror(-Z);
 135:   
 136:       web | rim;
 137:   }
 138:   
 139:   gear1 = Gear(90);
 140:   gear2 = Gear(60);
 141:   
 142:   gear1.reflect(X);
 143:   gear2
 144:       .rotate(gear2.tooth_angle * 50%)
 145:       .translate(
 146:           gear1.outer_radius + gear2.pitch_radius,
 147:           [1..3] * 360° / 3,
 148:       );
 149:   

