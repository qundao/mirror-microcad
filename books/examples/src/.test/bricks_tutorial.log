  81:   
  82:   use std::geo2d::*;
  83:   use std::ops::*;
  84:   
  85:   pub const SPACING = 8mm;
  86:   
  87:   op grid(columns: Integer, rows: Integer) {
  88:       @input
  89:           .translate(x = [1..columns] * SPACING, y = [1..rows] * SPACING)
  90:           .center()
  91:   }
  92:   
  93:   sketch Base(
  94:       columns: Integer,
  95:       rows: Integer,
  96:       width: Length,
  97:       height: Length
  98:   ) {
  99:       thickness = 1.2mm;
 100:       frame = Frame(width, height, thickness);
 101:       struts = Ring(outer_diameter = 6.51mm, inner_diameter = 4.8mm)
 102:           .grid(columns = columns-1, rows = rows-1);
 103:       frame | struts;
 104:   }
 105:   
 106:   use Rect as Cap;
 107:   
 108:   sketch Knobs(columns: Integer, rows: Integer) {
 109:       Circle(d = 4.8mm)
 110:           .grid(columns, rows);
 111:   }
 112:   
 113:   pub part LegoBrick(rows = 2, columns = 4, base_height = 9.6mm) {
 114:       width = columns * SPACING - 0.2mm;
 115:       height =rows * SPACING - 0.2mm;
 116:       cap_thickness = 1.0mm;
 117:   
 118:       base = Base(rows, columns, width, height)
 119:           .extrude(base_height - cap_thickness);
 120:   
 121:       cap = Cap(width, height)
 122:           .extrude(cap_thickness)
 123:           .translate(z = base_height - cap_thickness);
 124:   
 125:       knobs = Knobs(rows, columns)
 126:           .extrude(1.7mm)
 127:           .translate(z = base_height);
 128:   
 129:       base | cap | knobs;
 130:   }
 131:   
 132:   // render a brick with default values
 133:   LegoBrick();
 134:   

