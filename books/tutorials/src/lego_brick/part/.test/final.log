   9:   use std::geo2d::*;
  10:   use std::ops::*;
  11:   
  12:   const SPACING = 8mm;
  13:   
  14:   op grid(columns: Integer, rows: Integer) {
  15:       @input
  16:           .translate(x = [1..columns] * SPACING, y = [1..rows] * SPACING)
  17:           .center()
  18:   }
  19:   
  20:   sketch Base(columns: Integer, rows: Integer, width: Length, height: Length) {
  21:       thickness = 1.2mm;
  22:       frame = Frame(width, height, thickness);
  23:       struts = Ring(outer_diameter = 6.51mm, inner_diameter = 4.8mm)
  24:           .grid(columns = columns - 1, rows = rows - 1);
  25:       frame | struts;
  26:   }
  27:   
  28:   use Rect as Cap;
  29:   
  30:   sketch Knobs(columns: Integer, rows: Integer) {
  31:       Circle(diameter = 4.8mm)
  32:           .grid(columns, rows);
  33:   }
  34:   
  35:   part LegoBrick(rows = 2, columns = 4, base_height = 9.6mm) {
  36:       width = columns * SPACING - 0.2mm;
  37:       height = rows * SPACING - 0.2mm;
  38:       cap_thickness = 1.0mm;
  39:   
  40:       base = Base(rows, columns, width, height)
  41:           .extrude(base_height - cap_thickness);
  42:   
  43:       cap = Cap(width, height)
  44:           .extrude(cap_thickness)
  45:           .translate(z = base_height - cap_thickness);
  46:   
  47:       knobs = Knobs(rows, columns)
  48:           .extrude(1.7mm)
  49:           .translate(z = base_height);
  50:   
  51:       base | cap | knobs;
  52:   }
  53:   
  54:   // render a brick with default values
  55:   LegoBrick();

