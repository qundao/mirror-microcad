  35:   use std::geo2d::*;
  36:   use std::ops::*;
  37:   
  38:   const SPACING = 8mm;
  39:   
  40:   op grid(columns: Integer, rows: Integer) {
  41:       @input
  42:           .translate(x = [1..columns] * SPACING, y = [1..rows] * SPACING)
  43:           .center()
  44:   }
  45:   
  46:   sketch Base(columns: Integer, rows: Integer, width: Length, height: Length) {
  47:       thickness = 1.2mm;
  48:       frame = Frame(width, height, thickness);
  49:       struts = Ring(outer_diameter = 6.51mm, inner_diameter = 4.8mm)
  50:           .grid(columns = columns - 1, rows = rows - 1);
  51:       frame | struts;
  52:   }
  53:   
  54:   sketch Knobs(columns: Integer, rows: Integer) {
  55:       Circle(diameter = 4.8mm)
  56:           .grid(columns, rows);
  57:   }
  58:   
  59:   use Rect as Cap;
  60:   
  61:   columns = 4;
  62:   rows = 2;
  63:   width = columns * SPACING - 0.2mm;
  64:   height = rows * SPACING - 0.2mm;
  65:   
  66:   Base(rows, columns, width, height);
  67:   Cap(width, height);
  68:   Knobs(rows, columns);

